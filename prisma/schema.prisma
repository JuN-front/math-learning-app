generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  personal_id String   @unique
  username    String
  password    String
  role        String   @default("user")
  created_at  DateTime @default(now())

  progress    Progress[]
  assignments Assignment[]
}

model Unit {
  id          String    @id @default(cuid())
  title       String
  description String    @default("")
  order       Int
  created_at  DateTime  @default(now())

  contents    Content[]
}

model Content {
  id              String   @id @default(cuid())
  unit_id         String
  title           String
  description     String   @default("")
  order           Int
  has_video       Boolean  @default(false)
  has_textbook    Boolean  @default(false)
  has_assignment  Boolean  @default(false)
  video_path      String?
  textbook_path   String?
  assignment_path String?
  answer_path     String?
  lock_conditions String[] @default([])
  created_at      DateTime @default(now())

  unit        Unit         @relation(fields: [unit_id], references: [id], onDelete: Cascade)
  progress    Progress[]
  assignments Assignment[]
}

model Progress {
  id                   String   @id @default(cuid())
  user_id              String
  content_id           String
  status               String   @default("not_started")
  video_watched        Boolean  @default(false)
  textbook_read        Boolean  @default(false)
  assignment_submitted Boolean  @default(false)
  updated_at           DateTime @updatedAt

  user    User    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  content Content @relation(fields: [content_id], references: [id], onDelete: Cascade)

  @@unique([user_id, content_id])
}

model Assignment {
  id           String   @id @default(cuid())
  user_id      String
  content_id   String
  file_path    String
  filename     String
  submitted_at DateTime @default(now())

  user    User    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  content Content @relation(fields: [content_id], references: [id], onDelete: Cascade)

  @@unique([user_id, content_id])
}
